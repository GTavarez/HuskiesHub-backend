PORT=8080
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/huskieshub
JWT_SECRET=replace_with_a_long_random_secret
CALENDAR_ID=your_google_calendar_id
GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://www.eshuskiesyoffee.com,https://eshuskiesyoffee.com
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password
CONTACT_FROM_EMAIL=team@example.com
CONTACT_TO_EMAIL=team@example.com
# Stripe (test mode keys until real business/pricing info is confirmed)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Canonical frontend URL used to build Stripe Checkout success/cancel redirects
FRONTEND_URL=http://localhost:5173
# Server-side OpenWeather key for the analytics "weather alerts" tile — distinct
# from the frontend's VITE_OPENWEATHER_API_KEY (public WeatherBanner)
OPENWEATHER_API_KEY=your_openweather_api_key
# Anthropic API key for the AI assistant (Phase 5C) — user-supplied, test/dev only
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5
